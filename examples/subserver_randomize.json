    "balancers": [
      {
        "fallbackTag": "primary_fallback",
        "selector": ["primary", "primary_via_gateway"],
        "strategy": {
          "type": "leastPing"
        },
        "tag": "PROXY-BAL"
      },
      {
        "fallbackTag": "secondary_fallback",
        "selector": ["secondary", "secondary_via_gateway"],
        "strategy": {
          "type": "leastPing"
        },
        "tag": "RU-BAL"
      }
    ],
    "domainMatcher": "hybrid",
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "balancerTag": "RU-BAL",
        "domain": ["geosite:youtube", "geosite:discord", "geosite:soundcloud"],
        "type": "field"
      },
      {
        "ip": ["192.168.0.0/16"],
        "outboundTag": "direct",
        "type": "field"
      },
      {
        "outboundTag": "direct",
        "protocol": ["bittorrent"],
        "type": "field"
      },
      {
        "balancerTag": "PROXY-BAL",
        "inboundTag": ["socks", "http"],
