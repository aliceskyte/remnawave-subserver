# Subserver configuration
# Copy this file to /etc/subserver/subserver.env and fill in the values.

# Required: Remnawave panel URL (no trailing slash)
PANEL_URL=https://your-panel.example.com

# Required: Remnawave panel API token
PANEL_TOKEN=your-panel-token-here

# Required: local admin token for /admin/*
ADMIN_TOKEN=replace-with-a-long-random-secret

# Optional: Subscription path prefix (default: "/")
# SUB_PATH_PREFIX=/your-secret-prefix/

# Optional: Bind address (default: 127.0.0.1)
# SUBSERVER_BIND=127.0.0.1

# Optional: Port (default: 8080)
# SUBSERVER_PORT=8080

# Optional: path to the bootstrap config file mounted into /app/configs/default.json
# SUBSERVER_CONFIG_FILE=/etc/subserver/default.json

# Optional: Panel response cache TTL in seconds (default: 60)
# PANEL_CACHE_TTL=60

# Optional: Rate limit requests per second (default: 5)
# RATE_LIMIT_RPS=5

# Optional: Rate limit burst (default: same as RPS)
# RATE_LIMIT_BURST=5

# Optional: Admin API rate limit requests per second (default: 5)
# ADMIN_RATE_LIMIT_RPS=5

# Optional: Admin API rate limit burst (default: same as RPS)
# ADMIN_RATE_LIMIT_BURST=5

# Optional: Explicit trusted proxy CIDRs for X-Forwarded-For / X-Real-IP.
# By default only loopback proxies are trusted.
# TRUSTED_PROXY_CIDRS=127.0.0.1/32,172.18.0.0/16

# Optional: load local .env for development only (default: disabled)
# SUBSERVER_LOAD_DOTENV=1

# Optional: Database path (default: data/subserver.db)
# SUBSERVER_DB_PATH=data/subserver.db

# Optional: Database DSN (overrides DB_PATH)
# SUBSERVER_DB_DSN=file:data/subserver.db?_pragma=foreign_keys(1)&_pragma=busy_timeout(5000)
